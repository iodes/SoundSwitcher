<Page
    x:Class="SoundSwitcher.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:SoundSwitcher.Behaviors"
    xmlns:controls="clr-namespace:SoundSwitcher.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:SoundSwitcher.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="SettingsPage"
    d:DesignHeight="450"
    d:DesignWidth="440"
    mc:Ignorable="d">

    <Page.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:CardControl}}" TargetType="controls:CardToggleSwitch">
            <Setter Property="behaviors:AnimatedPressBehavior.HoverBackground" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>
    </Page.Resources>

    <StackPanel Margin="0,18,0,10" behaviors:MarginSetter.Margin="15,0,15,5">
        <ui:CardControl>
            <ui:CardControl.Icon>
                <ui:SymbolIcon Symbol="LocalLanguage24" />
            </ui:CardControl.Icon>
            <ui:CardControl.Header>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="13"
                        FontWeight="Medium"
                        Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Language]}" />
                    <TextBlock FontSize="12" Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[LanguageDesc]}" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox
                Width="180"
                DisplayMemberPath="Name"
                ItemsSource="{Binding AvailableLanguages}"
                SelectedValue="{Binding Language, Mode=TwoWay}"
                SelectedValuePath="Code" />
        </ui:CardControl>

        <controls:CardToggleSwitch IsChecked="{Binding RunAtStartup, Mode=TwoWay}">
            <controls:CardToggleSwitch.Icon>
                <ui:SymbolIcon Symbol="TasksApp24" />
            </controls:CardToggleSwitch.Icon>
            <controls:CardToggleSwitch.Header>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="13"
                        FontWeight="Medium"
                        Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[AutoStartup]}" />
                    <TextBlock FontSize="12" Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[AutoStartupDesc]}" />
                </StackPanel>
            </controls:CardToggleSwitch.Header>
        </controls:CardToggleSwitch>

        <controls:CardToggleSwitch IsChecked="{Binding SwitchCommunicationDevice, Mode=TwoWay}">
            <controls:CardToggleSwitch.Icon>
                <ui:SymbolIcon Symbol="ArrowSwap24" />
            </controls:CardToggleSwitch.Icon>
            <controls:CardToggleSwitch.Header>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="13"
                        FontWeight="Medium"
                        Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[SwitchCommunicationDevice]}" />
                    <TextBlock FontSize="12" Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[SwitchCommunicationDeviceDesc]}" />
                </StackPanel>
            </controls:CardToggleSwitch.Header>
        </controls:CardToggleSwitch>

        <controls:CardToggleSwitch IsChecked="{Binding ShowUnavailableDevices, Mode=TwoWay}">
            <controls:CardToggleSwitch.Icon>
                <ui:SymbolIcon Symbol="Eye24" />
            </controls:CardToggleSwitch.Icon>
            <controls:CardToggleSwitch.Header>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="13"
                        FontWeight="Medium"
                        Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[ShowUnavailableDevices]}" />
                    <TextBlock FontSize="12" Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[ShowUnavailableDevicesDesc]}" />
                </StackPanel>
            </controls:CardToggleSwitch.Header>
        </controls:CardToggleSwitch>

        <controls:CardToggleSwitch IsChecked="{Binding ShowProfileIconInTray, Mode=TwoWay}">
            <controls:CardToggleSwitch.Icon>
                <ui:SymbolIcon Symbol="Image24" />
            </controls:CardToggleSwitch.Icon>
            <controls:CardToggleSwitch.Header>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="13"
                        FontWeight="Medium"
                        Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[ShowProfileIconInTray]}" />
                    <TextBlock FontSize="12" Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[ShowProfileIconInTrayDesc]}" />
                </StackPanel>
            </controls:CardToggleSwitch.Header>
        </controls:CardToggleSwitch>

        <controls:CardToggleSwitch IsChecked="{Binding ShowProfileChangeNotification, Mode=TwoWay}">
            <controls:CardToggleSwitch.Icon>
                <ui:SymbolIcon Symbol="Alert24" />
            </controls:CardToggleSwitch.Icon>
            <controls:CardToggleSwitch.Header>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="13"
                        FontWeight="Medium"
                        Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[ShowProfileChangeNotification]}" />
                    <TextBlock FontSize="12" Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[ShowProfileChangeNotificationDesc]}" />
                </StackPanel>
            </controls:CardToggleSwitch.Header>
        </controls:CardToggleSwitch>
    </StackPanel>
</Page>