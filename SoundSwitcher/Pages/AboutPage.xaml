<Page
    x:Class="SoundSwitcher.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:SoundSwitcher.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="AboutPage"
    d:DesignHeight="450"
    d:DesignWidth="440"
    mc:Ignorable="d">

    <StackPanel Margin="0,18,0,10" behaviors:MarginSetter.Margin="15,0,15,5">
        <ui:CardControl>
            <ui:CardControl.Icon>
                <ui:SymbolIcon Symbol="Tag24" />
            </ui:CardControl.Icon>
            <ui:CardControl.Header>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="13"
                        FontWeight="Medium"
                        Text="프로그램 버전" />
                    <TextBlock FontSize="12" Text="{Binding AppVersion}" />
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardAction
            x:Name="BtnCheckUpdate"
            Click="BtnCheckUpdate_OnClick"
            IsChevronVisible="True">
            <ui:CardAction.Icon>
                <ui:SymbolIcon Symbol="ArrowCounterclockwise24" />
            </ui:CardAction.Icon>
            <StackPanel VerticalAlignment="Center">
                <TextBlock
                    FontSize="13"
                    FontWeight="Medium"
                    Text="업데이트 확인" />
                <TextBlock FontSize="12" Text="프로그램의 최신 업데이트를 확인 및 설치합니다." />
            </StackPanel>
        </ui:CardAction>

        <ui:CardAction
            x:Name="BtnOpenHomepage"
            Click="BtnOpenHomepage_OnClick"
            IsChevronVisible="True">
            <ui:CardAction.Icon>
                <ui:SymbolIcon Symbol="Open24" />
            </ui:CardAction.Icon>
            <StackPanel VerticalAlignment="Center">
                <TextBlock
                    FontSize="13"
                    FontWeight="Medium"
                    Text="홈페이지" />
                <TextBlock FontSize="12" Text="프로그램의 공식 홈페이지를 방문합니다." />
            </StackPanel>
        </ui:CardAction>
    </StackPanel>
</Page>