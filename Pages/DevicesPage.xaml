<Page
    x:Class="SoundSwitcher.Pages.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:SoundSwitcher.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SoundSwitcher.ViewModels"
    xmlns:dd="urn:gong-wpf-dragdrop"
    Title="DevicesPage"
    d:DesignHeight="500"
    d:DesignWidth="440"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:NullToVisibilityConverter x:Key="NullToVis" xmlns:local="clr-namespace:SoundSwitcher.Pages" />
        <local:NullToVisibilityConverter x:Key="NotNullToVis" Invert="True" xmlns:local="clr-namespace:SoundSwitcher.Pages" />
    </Page.Resources>

    <StackPanel Margin="0,18,0,10" behaviors:MarginSetter.Margin="15,0,15,5">
        <!-- Profile List -->
        <ItemsControl ItemsSource="{Binding Profiles}" x:Name="ProfileItemsControl">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:DeviceProfileViewModel}">
                    <Border Margin="0,0,0,8" Padding="12" 
                            BorderThickness="1" 
                            CornerRadius="4"
                            RenderTransformOrigin="0.5,0.5"
                            Loaded="ProfileBorder_Loaded"
                            ContextMenuOpening="ProfileBorder_ContextMenuOpening"
                            ContextMenuClosing="ProfileBorder_ContextMenuClosing">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="기본 아이콘으로 초기화" Command="{Binding ResetIconCommand}" 
                                          Visibility="{Binding IconPath, Converter={StaticResource NotNullToVis}}" />
                                <MenuItem Header="삭제" Command="{Binding DeleteCommand}" />
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Border.Resources>
                            <Storyboard x:Key="LoadStoryboard" FillBehavior="Stop">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.Y)" From="30" To="0" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(ScaleTransform.ScaleY)" From="0" To="1" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </Border.Resources>
                        <Border.LayoutTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.LayoutTransform>
                        <Border.RenderTransform>
                            <TransformGroup>
                                <TranslateTransform X="0" Y="0" />
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid x:Name="CardGrid" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <!-- Grip -->
                                <ColumnDefinition Width="Auto" />
                                <!-- Icon -->
                                <ColumnDefinition Width="Auto" />
                                <!-- Content -->
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Grip Handle -->
                            <Border Grid.Column="0" Margin="0,0,12,0" 
                                    Background="Transparent" 
                                    Cursor="SizeAll" 
                                    VerticalAlignment="Center"
                                    behaviors:LiveReorderBehavior.IsReorderGrip="True">
                                <ui:SymbolIcon Symbol="ReOrderDotsVertical24" Foreground="Gray" />
                            </Border>

                            <!-- Icon Area -->
                            <Grid Grid.Column="1" Width="40" Margin="0,0,12,0" VerticalAlignment="Center" Cursor="Hand">
                                <Grid.InputBindings>
                                    <MouseBinding Gesture="LeftClick" Command="{Binding ChangeIconCommand}" />
                                </Grid.InputBindings>
                                <Border CornerRadius="4" Background="Transparent" ToolTip="아이콘 변경 (좌클릭)">
                                    <Grid>
                                        <!-- Default Icon (Native or Symbol fallback) -->
                                        <Grid Visibility="{Binding IconPath, Converter={StaticResource NullToVis}}">
                                            <!-- Built-in Symbol Fallback -->
                                            <ui:SymbolIcon Symbol="Speaker224" FontSize="28" Foreground="Gray" 
                                                           Visibility="{Binding FallbackDeviceIcon, Converter={StaticResource NullToVis}}" />
                                            <!-- Native Device Icon -->
                                            <Image Source="{Binding FallbackDeviceIcon}" Width="32" Height="32" Stretch="Uniform" 
                                                   Visibility="{Binding FallbackDeviceIcon, Converter={StaticResource NotNullToVis}}" />
                                        </Grid>
                                        
                                        <!-- Custom Icon -->
                                        <Image Source="{Binding IconPath}" Width="40" Height="40" Stretch="UniformToFill" 
                                               Visibility="{Binding IconPath, Converter={StaticResource NotNullToVis}}" />
                                        
                                        <!-- Active Checkmark Overlay -->
                                        <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                              Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                            <Ellipse Width="16" Height="16" Fill="#107C10" />
                                            <ui:SymbolIcon Symbol="Checkmark12" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Profile Content -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Speaker224" Margin="0,0,4,0"/>
                                        <TextBlock Text="출력" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding DataContext.AvailablePlaybackDevices, RelativeSource={RelativeSource AncestorType=Page}}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="DeviceId"
                                              SelectedValue="{Binding PlaybackDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Mic24" Margin="0,0,4,0"/>
                                        <TextBlock Text="입력" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding DataContext.AvailableCaptureDevices, RelativeSource={RelativeSource AncestorType=Page}}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="DeviceId"
                                              SelectedValue="{Binding CaptureDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDeleting}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.35">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.Y)" To="30" Duration="0:0:0.35">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(ScaleTransform.ScaleY)" To="0" Duration="0:0:0.35">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFocused}" Value="True">
                                        <Setter Property="Background" Value="#1A0078D7" />
                                        <Setter Property="BorderBrush" Value="#330078D7" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Add Button -->
        <Button Command="{Binding AddProfileCommand}" 
                Background="Transparent" 
                BorderThickness="0" 
                Padding="0" 
                Margin="0,4,0,0"
                Cursor="Hand"
                HorizontalAlignment="Stretch">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid Background="Transparent">
                        <Rectangle StrokeDashArray="4 4" Stroke="Gray" StrokeThickness="2" RadiusX="4" RadiusY="4" Fill="Transparent" />
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16" />
                    </Grid>
                </ControlTemplate>
            </Button.Template>
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Add24" Margin="0,0,8,0" />
                <TextBlock Text="새 프로파일 추가" FontWeight="SemiBold" />
            </StackPanel>
        </Button>
    </StackPanel>
</Page>
